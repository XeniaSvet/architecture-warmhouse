@startuml
title Warmhouse Web Application Component Diagram

top to bottom direction

!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml

Container_Boundary(Warmhouse, "Warmhouse System") {
  Container(DevicesService, "Devices Service", "Go", "Управление данными устройств")
  SystemDb(DevicesDatabase, "Devices Database", "PostgreSQL", "Данные об устройствах")
}

Container(DevicesService, "Devices Service", "Go") {
  Component(AddDeviceController, "AddDeviceController", "Manages user profiles")
  Component(DeleteDeviceController, "DeleteDeviceController", "Manages devices")
  Component(UpdateDeviceController, "UpdateDeviceController", "Manages devices")
  Component(ServiceLayer, "Service Layer", "Business logic")
  Component(RepositoryLayer, "Repository Layer", "Data access logic")
}

System_Ext(SmartDevices, "Smart Devices", "Умные устройства партнеров")

Rel(AddDeviceController,ServiceLayer,"Добавление нового устройства")
Rel(AddDeviceController,SmartDevices,"Подключение устройства партнера")
Rel(DeleteDeviceController,ServiceLayer,"Удаление устройства")
Rel(UpdateDeviceController,ServiceLayer,"Обновление данных об устройстве")
Rel(ServiceLayer,RepositoryLayer,"Чтение/запись данных")
Rel(RepositoryLayer,DevicesDatabase,"Чтение/запись данных об устройствах")
@enduml