@startuml
title Warmhouse Web Application Component Diagram

top to bottom direction

!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml

Container_Boundary(Warmhouse, "Warmhouse System") {
  Container(WebApp, "Web Application", "Java, Spring", "Обработка запросов пользователя")
  Container(UserService, "User Service", "Go", "Управление данными пользователя")
  Container(MonitoringService, "Monitoring Service", "Go", "Мониторинг температуры")
  Container(DevicesService, "Devices Service", "Go", "Управление устройствами")
}

Container(WebApp, "Web Application", "Java, Spring") {
  Component(UserController, "UserController", "Manages user profiles")
  Component(DevicesController, "DevicesController", "Manages devices")
  Component(MonitoringController, "MonitoringController", "Manages monitoring")
  Component(ServiceLayer, "Service Layer", "Business logic")
}

Rel(UserController,ServiceLayer,"Calls business logic")
Rel(DevicesController,ServiceLayer,"Calls business logic")
Rel(MonitoringController,ServiceLayer,"Calls business logic")
Rel(ServiceLayer,UserService,"Reads/Writes user data")
Rel(ServiceLayer,MonitoringService,"Reads/Writes devices data")
Rel(ServiceLayer,DevicesService,"Reads monitoring data")
@enduml