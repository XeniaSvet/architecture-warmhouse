@startuml
title Warmhouse Web Application Component Diagram

top to bottom direction

!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml

Container_Boundary(Warmhouse, "Warmhouse System") {
  Container(UserService, "User Service", "Go", "Мониторинг показателей датчиков")
  SystemDb(MonitoringDatabase, "Monitoring Database", "PostgreSQL", "Данные о мониторинге показателей")
}

Container(UserService, "User Service", "Go") {
  Component(ManagerMonitoringController, "MonitoringController", "Управление системой мониторинга")
  Component(CurrentMonitoringController, "CurrentMonitoringController", "Получение текущих данных датчиков")
  Component(ConsumerMonitoringController, "ConsumerMonitoringController", "Получение даггых с датчиков в реальном времени")
  Component(ServiceLayer, "Service Layer", "Business logic")
  Component(RepositoryLayer, "Repository Layer", "Data access logic")
}

Rel(ManagerMonitoringController,ServiceLayer,"Управление системой мониторинга")
Rel(CurrentMonitoringController,ServiceLayer,"Получение текущих данных датчиков")
Rel(ConsumerMonitoringController,ServiceLayer,"Получение даггых с датчиков в реальном времени")
Rel(ServiceLayer,RepositoryLayer,"Reads data")
Rel(RepositoryLayer,MonitoringDatabase,"Reads monitoring data")
@enduml